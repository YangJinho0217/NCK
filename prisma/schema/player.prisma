model Player {
  id        Int       @id @default(autoincrement())
  loginId   String    @map("login_id") @db.VarChar(100) // 로그인 아이디
  nickName  String    @map("nick_name") @db.VarChar(100) // 닉네임
  password  String    @map("password") @db.VarChar(100) // 비밀번호
  isActive  Boolean   @default(true) @map("is_active") // 활성화 여부
  deletedAt DateTime? @map("deleted_at") // 삭제 일시
  createdAt DateTime  @default(now()) @map("created_at") // 생성 일시
  updatedAt DateTime  @updatedAt @map("updated_at") // 수정 일시

  playerSettings PlayerSetting[]

  @@index([loginId])
  @@map("player")
}

model PlayerSetting {
  id              Int       @id @default(autoincrement())
  playerId        Int       @map("player_id") // 플레이어 아이디
  leagueId        String?   @map("league_id") @db.VarChar(100) // 리그 아이디
  gameNickName    String?   @map("game_nickname") @db.VarChar(50) // 게임 닉네임
  gameTag         String?   @map("game_tag") @db.VarChar(20) // 게임 태그
  tier            String?   @map("tier") @db.VarChar(20) // 티어 
  rank            String?   @map("rank") @db.VarChar(10) // 랭크
  puuid           String?   @map("puuid") @db.VarChar(300) // 플레이어 고유 아이디
  totalPlayGame   Int       @default(0) @map("total_play_game") // 총 플레이 게임 수
  likedPosition   Json      @default("{\"top\": false, \"jungle\": false, \"mid\": false, \"adc\": false, \"support\": false, \"allround\": false}") @map("liked_position") // 좋아하는 포지션
  unlikedPosition Json      @default("{\"top\": false, \"jungle\": false, \"mid\": false, \"adc\": false, \"support\": false, \"allround\": false}") @map("unliked_position") // 싫어하는 포지션
  deletedAt       DateTime? @map("deleted_at") // 삭제 일시
  createdAt       DateTime  @default(now()) @map("created_at") // 생성 일시
  updatedAt       DateTime  @updatedAt @map("updated_at") // 수정 일시

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("player_setting")
}
